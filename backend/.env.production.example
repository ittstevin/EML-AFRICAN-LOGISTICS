# Backend Production Environment Template
# Copy this to backend/.env.production and fill in your values

# Database URL
# For SQLite (file-based):
DATABASE_URL="file:./prod.db"

# For PostgreSQL (recommended for production):
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-secure-random-secret-here-change-this"

# Server Configuration
PORT=5000
NODE_ENV="production"

# CORS - Set to your Vercel frontend URL
CORS_ORIGIN="https://your-vercel-app.vercel.app"

# Optional: Add other configuration as needed
LOG_LEVEL="info"
